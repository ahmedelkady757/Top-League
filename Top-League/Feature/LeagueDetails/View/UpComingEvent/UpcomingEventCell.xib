<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23727" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23721"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="collection view cell content view" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell contentMode="scaleToFill" id="uEC-ce-ll1" customClass="UpcomingEventCell" customModule="Top_League" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="360" height="150"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="uEC-cv-cnt">
                <rect key="frame" x="0.0" y="0.0" width="360" height="150"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <!-- Card background view -->
                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-card">
                        <rect key="frame" x="8" y="6" width="344" height="138"/>
                        <color key="backgroundColor" red="0.074" green="0.098" blue="0.157" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <subviews>
                            <!-- LIVE badge container -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-live-view">
                                <rect key="frame" x="152" y="8" width="40" height="18"/>
                                <color key="backgroundColor" red="1" green="0.231" blue="0.188" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="LIVE" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-live-lbl">
                                        <rect key="frame" x="0" y="0" width="40" height="18"/>
                                        <fontDescription key="fontDescription" type="boldSystem" pointSize="10"/>
                                        <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                        <nil key="highlightedColor"/>
                                        <constraints>
                                            <constraint firstAttribute="width" constant="40" id="uEC-llw"/>
                                            <constraint firstAttribute="height" constant="18" id="uEC-llh"/>
                                        </constraints>
                                    </label>
                                </subviews>
                                <constraints>
                                    <constraint firstAttribute="width" constant="40" id="uEC-lvw"/>
                                    <constraint firstAttribute="height" constant="18" id="uEC-lvh"/>
                                </constraints>
                            </view>
                            <!-- Home Logo -->
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-home-img">
                                <rect key="frame" x="16" y="24" width="50" height="50"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="50" id="uEC-hiw"/>
                                    <constraint firstAttribute="height" constant="50" id="uEC-hih"/>
                                </constraints>
                            </imageView>
                            <!-- VS label -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="VS" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-vs">
                                <rect key="frame" x="157" y="39" width="30" height="20"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="16"/>
                                <color key="textColor" red="0.961" green="0.773" blue="0.094" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="30" id="uEC-vsw"/>
                                </constraints>
                            </label>
                            <!-- Away Logo -->
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-away-img">
                                <rect key="frame" x="278" y="24" width="50" height="50"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="50" id="uEC-aiw"/>
                                    <constraint firstAttribute="height" constant="50" id="uEC-aih"/>
                                </constraints>
                            </imageView>
                            <!-- Home Name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Home Team" textAlignment="right" lineBreakMode="middleTruncation" numberOfLines="2" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-home-lbl">
                                <rect key="frame" x="74" y="40" width="75" height="14.333333333333336"/>
                                <fontDescription key="fontDescription" type="system" pointSize="12"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Away Name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Away Team" textAlignment="left" lineBreakMode="middleTruncation" numberOfLines="2" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-away-lbl">
                                <rect key="frame" x="195" y="40" width="75" height="14.333333333333336"/>
                                <fontDescription key="fontDescription" type="system" pointSize="12"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Time Label -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="18:00" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-time">
                                <rect key="frame" x="156.66666666666666" y="83" width="31" height="14.333333333333329"/>
                                <fontDescription key="fontDescription" type="system" pointSize="12"/>
                                <color key="textColor" red="0.961" green="0.773" blue="0.094" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Date Label -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Sep 01, 2025" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="uEC-date">
                                <rect key="frame" x="139.66666666666666" y="101.33333333333333" width="65" height="12"/>
                                <fontDescription key="fontDescription" type="system" pointSize="10"/>
                                <color key="textColor" red="0.557" green="0.608" blue="0.710" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <!-- Card constraints -->
                        <constraints>
                            <constraint firstItem="uEC-live-view" firstAttribute="top" secondItem="uEC-card" secondAttribute="top" constant="12" id="uEC-c1"/>
                            <constraint firstItem="uEC-live-view" firstAttribute="trailing" secondItem="uEC-card" secondAttribute="trailing" constant="-12" id="uEC-c2"/>
                            
                            <constraint firstItem="uEC-home-img" firstAttribute="leading" secondItem="uEC-card" secondAttribute="leading" constant="16" id="uEC-c3"/>
                            <constraint firstItem="uEC-home-img" firstAttribute="centerY" secondItem="uEC-card" secondAttribute="centerY" constant="-20" id="uEC-c4"/>
                            
                            <constraint firstItem="uEC-vs" firstAttribute="centerX" secondItem="uEC-card" secondAttribute="centerX" id="uEC-c5"/>
                            <constraint firstItem="uEC-vs" firstAttribute="centerY" secondItem="uEC-home-img" secondAttribute="centerY" id="uEC-c6"/>
                            
                            <constraint firstItem="uEC-away-img" firstAttribute="trailing" secondItem="uEC-card" secondAttribute="trailing" constant="-16" id="uEC-c7"/>
                            <constraint firstItem="uEC-away-img" firstAttribute="centerY" secondItem="uEC-home-img" secondAttribute="centerY" id="uEC-c8"/>
                            
                            <constraint firstItem="uEC-home-lbl" firstAttribute="leading" secondItem="uEC-home-img" secondAttribute="trailing" constant="8" id="uEC-c18"/>
                            <constraint firstItem="uEC-home-lbl" firstAttribute="trailing" secondItem="uEC-vs" secondAttribute="leading" constant="-8" id="uEC-c19"/>
                            <constraint firstItem="uEC-home-lbl" firstAttribute="centerY" secondItem="uEC-home-img" secondAttribute="centerY" id="uEC-c20"/>

                            <constraint firstItem="uEC-away-lbl" firstAttribute="leading" secondItem="uEC-vs" secondAttribute="trailing" constant="8" id="uEC-c15"/>
                            <constraint firstItem="uEC-away-lbl" firstAttribute="trailing" secondItem="uEC-away-img" secondAttribute="leading" constant="-8" id="uEC-c16"/>
                            <constraint firstItem="uEC-away-lbl" firstAttribute="centerY" secondItem="uEC-vs" secondAttribute="centerY" id="uEC-c17"/>

                            <constraint firstItem="uEC-time" firstAttribute="centerX" secondItem="uEC-card" secondAttribute="centerX" id="uEC-c12"/>
                            <constraint firstItem="uEC-time" firstAttribute="top" secondItem="uEC-vs" secondAttribute="bottom" constant="24" id="uEC-c13"/>
                            
                            <constraint firstItem="uEC-date" firstAttribute="centerX" secondItem="uEC-card" secondAttribute="centerX" id="uEC-c10"/>
                            <constraint firstItem="uEC-date" firstAttribute="top" secondItem="uEC-time" secondAttribute="bottom" constant="4" id="uEC-c11"/>
                        </constraints>
                    </view>
                </subviews>
                <!-- Card to contentView -->
                <constraints>
                    <constraint firstItem="uEC-card" firstAttribute="top" secondItem="uEC-cv-cnt" secondAttribute="top" constant="6" id="uEC-cv1"/>
                    <constraint firstItem="uEC-card" firstAttribute="bottom" secondItem="uEC-cv-cnt" secondAttribute="bottom" constant="-6" id="uEC-cv2"/>
                    <constraint firstItem="uEC-card" firstAttribute="leading" secondItem="uEC-cv-cnt" secondAttribute="leading" constant="8" id="uEC-cv3"/>
                    <constraint firstItem="uEC-card" firstAttribute="trailing" secondItem="uEC-cv-cnt" secondAttribute="trailing" constant="-8" id="uEC-cv4"/>
                </constraints>
            </collectionViewCellContentView>
            <viewLayoutGuide key="safeArea" id="uEC-sa"/>
            <connections>
                <outlet property="cardView"       destination="uEC-card"      id="uEC-o1"/>
                <outlet property="homeLogoImage"  destination="uEC-home-img"  id="uEC-o2"/>
                <outlet property="awayLogoImage"  destination="uEC-away-img"  id="uEC-o3"/>
                <outlet property="homeNameLabel"  destination="uEC-home-lbl"  id="uEC-o4"/>
                <outlet property="awayNameLabel"  destination="uEC-away-lbl"  id="uEC-o5"/>
                <outlet property="vsLabel"        destination="uEC-vs"        id="uEC-o6"/>
                <outlet property="dateLabel"      destination="uEC-date"      id="uEC-o7"/>
                <outlet property="timeLabel"      destination="uEC-time"      id="uEC-o8"/>
                <outlet property="liveBadgeView"  destination="uEC-live-view" id="uEC-o9"/>
                <outlet property="liveBadgeLabel" destination="uEC-live-lbl"  id="uEC-o10"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>
