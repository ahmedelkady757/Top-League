<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23727" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23721"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="collection view cell content view" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell contentMode="scaleToFill" id="tC-ce-ll1" customClass="TeamCell" customModule="Top_League" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="100" height="120"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="tC-cv-cnt">
                <rect key="frame" x="0.0" y="0.0" width="100" height="120"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <!-- Card -->
                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="tC-card">
                        <rect key="frame" x="5" y="5" width="90" height="110"/>
                        <color key="backgroundColor" red="0.074" green="0.098" blue="0.157" alpha="0.8" colorSpace="custom" customColorSpace="sRGB"/>
                        <subviews>
                            <!-- Ring View -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="tC-ring">
                                <rect key="frame" x="13" y="10" width="64" height="64"/>
                                <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
                                <subviews>
                                    <!-- Logo Image -->
                                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="tC-logo">
                                        <rect key="frame" x="4" y="4" width="56" height="56"/>
                                        <constraints>
                                            <constraint firstAttribute="width"  constant="56" id="tC-lw"/>
                                            <constraint firstAttribute="height" constant="56" id="tC-lh"/>
                                        </constraints>
                                    </imageView>
                                </subviews>
                                <constraints>
                                    <constraint firstAttribute="width"  constant="64" id="tC-rw"/>
                                    <constraint firstAttribute="height" constant="64" id="tC-rh"/>
                                    <constraint firstItem="tC-logo" firstAttribute="centerX" secondItem="tC-ring" secondAttribute="centerX" id="tC-lcx"/>
                                    <constraint firstItem="tC-logo" firstAttribute="centerY" secondItem="tC-ring" secondAttribute="centerY" id="tC-lcy"/>
                                </constraints>
                            </view>
                            <!-- Team Name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Team Name" textAlignment="center" lineBreakMode="middleTruncation" numberOfLines="2" translatesAutoresizingMaskIntoConstraints="NO" id="tC-name">
                                <rect key="frame" x="4" y="78" width="82" height="26"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="11"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <!-- Card internal constraints -->
                        <constraints>
                            <constraint firstItem="tC-ring" firstAttribute="centerX" secondItem="tC-card" secondAttribute="centerX" id="tC-c1"/>
                            <constraint firstItem="tC-ring" firstAttribute="top"     secondItem="tC-card" secondAttribute="top"     constant="10" id="tC-c2"/>
                            <constraint firstItem="tC-name" firstAttribute="top"     secondItem="tC-ring" secondAttribute="bottom"  constant="4"  id="tC-c3"/>
                            <constraint firstItem="tC-name" firstAttribute="leading" secondItem="tC-card" secondAttribute="leading" constant="4"  id="tC-c4"/>
                            <constraint firstItem="tC-name" firstAttribute="trailing" secondItem="tC-card" secondAttribute="trailing" constant="-4" id="tC-c5"/>
                        </constraints>
                    </view>
                </subviews>
                <!-- Card to contentView -->
                <constraints>
                    <constraint firstItem="tC-card" firstAttribute="top"      secondItem="tC-cv-cnt" secondAttribute="top"      constant="5"  id="tC-cv1"/>
                    <constraint firstItem="tC-card" firstAttribute="bottom"   secondItem="tC-cv-cnt" secondAttribute="bottom"   constant="-5" id="tC-cv2"/>
                    <constraint firstItem="tC-card" firstAttribute="leading"  secondItem="tC-cv-cnt" secondAttribute="leading"  constant="5"  id="tC-cv3"/>
                    <constraint firstItem="tC-card" firstAttribute="trailing" secondItem="tC-cv-cnt" secondAttribute="trailing" constant="-5" id="tC-cv4"/>
                </constraints>
            </collectionViewCellContentView>
            <viewLayoutGuide key="safeArea" id="tC-sa"/>
            <connections>
                <outlet property="cardView"      destination="tC-card" id="tC-o1"/>
                <outlet property="ringView"      destination="tC-ring" id="tC-o2"/>
                <outlet property="logoImageView" destination="tC-logo" id="tC-o3"/>
                <outlet property="teamNameLabel" destination="tC-name" id="tC-o4"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>
