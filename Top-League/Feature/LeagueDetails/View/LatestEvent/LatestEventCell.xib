<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23727" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23721"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="collection view cell content view" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell contentMode="scaleToFill" id="lEC-ce-ll1" customClass="LatestEventCell" customModule="Top_League" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="360" height="80"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="lEC-cv-cnt">
                <rect key="frame" x="0.0" y="0.0" width="360" height="80"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <!-- Card -->
                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-card">
                        <rect key="frame" x="8" y="6" width="344" height="68"/>
                        <color key="backgroundColor" red="0.074" green="0.098" blue="0.157" alpha="0.92" colorSpace="custom" customColorSpace="sRGB"/>
                        <subviews>
                            <!-- Home Logo -->
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-home-img">
                                <rect key="frame" x="10" y="16" width="36" height="36"/>
                                <constraints>
                                    <constraint firstAttribute="width" secondItem="lEC-home-img" secondAttribute="height" multiplier="1:1" id="lEC-hiw"/>
                                </constraints>
                            </imageView>
                            <!-- Home Name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Home Team" textAlignment="right" lineBreakMode="middleTruncation" numberOfLines="1" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-home-lbl">
                                <rect key="frame" x="54" y="25" width="80" height="18"/>
                                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="14"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Score Label -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="2 - 1" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-score">
                                <rect key="frame" x="144" y="20" width="56" height="28"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="24"/>
                                <color key="textColor" red="0.961" green="0.773" blue="0.094" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="56" id="lEC-sw"/>
                                </constraints>
                            </label>
                            <!-- Away Name -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Away Team" textAlignment="left" lineBreakMode="middleTruncation" numberOfLines="1" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-away-lbl">
                                <rect key="frame" x="210" y="25" width="80" height="18"/>
                                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="14"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Away Logo -->
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-away-img">
                                <rect key="frame" x="298" y="16" width="36" height="36"/>
                                <constraints>
                                    <constraint firstAttribute="width" secondItem="lEC-away-img" secondAttribute="height" multiplier="1:1" id="lEC-aiw"/>
                                </constraints>
                            </imageView>
                            <!-- Date Label -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Sep 01, 2025" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-date">
                                <rect key="frame" x="120" y="52" width="104" height="12"/>
                                <fontDescription key="fontDescription" type="system" weight="medium" pointSize="11"/>
                                <color key="textColor" red="0.557" green="0.608" blue="0.710" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- Status Badge View -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-st-view">
                                <rect key="frame" x="306" y="51" width="30" height="14"/>
                                <color key="backgroundColor" red="0.118" green="0.165" blue="0.271" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <subviews>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="FT" textAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="lEC-st-lbl">
                                        <rect key="frame" x="0" y="0" width="30" height="14"/>
                                        <fontDescription key="fontDescription" type="boldSystem" pointSize="9"/>
                                        <color key="textColor" red="0.557" green="0.608" blue="0.710" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        <nil key="highlightedColor"/>
                                        <constraints>
                                            <constraint firstAttribute="width"  constant="30" id="lEC-slw"/>
                                            <constraint firstAttribute="height" constant="14" id="lEC-slh"/>
                                        </constraints>
                                    </label>
                                </subviews>
                                <constraints>
                                    <constraint firstAttribute="width"  constant="30" id="lEC-svw"/>
                                    <constraint firstAttribute="height" constant="14" id="lEC-svh"/>
                                </constraints>
                            </view>
                        </subviews>
                        <!-- Card internal constraints -->
                        <constraints>
                            <!-- Home Logo -->
                            <constraint firstItem="lEC-home-img" firstAttribute="leading"  secondItem="lEC-card" secondAttribute="leading"  constant="10" id="lEC-c1"/>
                            <constraint firstItem="lEC-home-img" firstAttribute="centerY"  secondItem="lEC-card" secondAttribute="centerY"  constant="-8" id="lEC-c2"/>
                            <constraint firstItem="lEC-home-img" firstAttribute="height" secondItem="lEC-card" secondAttribute="height" multiplier="0.45" id="lEC-c4h"/>
                            <!-- Home Name -->
                            <constraint firstItem="lEC-home-lbl" firstAttribute="leading"  secondItem="lEC-home-img" secondAttribute="trailing" constant="8"  id="lEC-c3"/>
                            <constraint firstItem="lEC-home-lbl" firstAttribute="trailing" secondItem="lEC-score"    secondAttribute="leading"  constant="-8" id="lEC-c4"/>
                            <constraint firstItem="lEC-home-lbl" firstAttribute="centerY"  secondItem="lEC-home-img" secondAttribute="centerY"             id="lEC-c5"/>
                            <!-- Score -->
                            <constraint firstItem="lEC-score" firstAttribute="centerX" secondItem="lEC-card" secondAttribute="centerX" id="lEC-c6"/>
                            <constraint firstItem="lEC-score" firstAttribute="centerY" secondItem="lEC-card" secondAttribute="centerY" constant="-8" id="lEC-c7"/>
                            <!-- Away Name -->
                            <constraint firstItem="lEC-away-lbl" firstAttribute="leading"  secondItem="lEC-score"    secondAttribute="trailing" constant="8"  id="lEC-c8"/>
                            <constraint firstItem="lEC-away-lbl" firstAttribute="trailing" secondItem="lEC-away-img" secondAttribute="leading"  constant="-8" id="lEC-c9"/>
                            <constraint firstItem="lEC-away-lbl" firstAttribute="centerY"  secondItem="lEC-score"    secondAttribute="centerY"              id="lEC-c10"/>
                            <!-- Away Logo -->
                            <constraint firstItem="lEC-away-img" firstAttribute="trailing" secondItem="lEC-card" secondAttribute="trailing" constant="-10" id="lEC-c11"/>
                            <constraint firstItem="lEC-away-img" firstAttribute="centerY"  secondItem="lEC-home-img" secondAttribute="centerY"              id="lEC-c12"/>
                            <constraint firstItem="lEC-away-img" firstAttribute="height" secondItem="lEC-home-img" secondAttribute="height" id="lEC-c8h"/>
                            <!-- Date -->
                            <constraint firstItem="lEC-date" firstAttribute="centerX" secondItem="lEC-card" secondAttribute="centerX" id="lEC-c13"/>
                            <constraint firstItem="lEC-date" firstAttribute="top" secondItem="lEC-score" secondAttribute="bottom" constant="4" id="lEC-c14"/>
                            <!-- Status badge -->
                            <constraint firstItem="lEC-st-view" firstAttribute="trailing" secondItem="lEC-card" secondAttribute="trailing" constant="-8" id="lEC-c15"/>
                            <constraint firstItem="lEC-st-view" firstAttribute="top"  secondItem="lEC-card"  secondAttribute="top" constant="8" id="lEC-c16"/>
                        </constraints>
                    </view>
                </subviews>
                <!-- Card to contentView -->
                <constraints>
                    <constraint firstItem="lEC-card" firstAttribute="top"      secondItem="lEC-cv-cnt" secondAttribute="top"      constant="6"  id="lEC-cv1"/>
                    <constraint firstItem="lEC-card" firstAttribute="bottom"   secondItem="lEC-cv-cnt" secondAttribute="bottom"   constant="-6" id="lEC-cv2"/>
                    <constraint firstItem="lEC-card" firstAttribute="leading"  secondItem="lEC-cv-cnt" secondAttribute="leading"  constant="8"  id="lEC-cv3"/>
                    <constraint firstItem="lEC-card" firstAttribute="trailing" secondItem="lEC-cv-cnt" secondAttribute="trailing" constant="-8" id="lEC-cv4"/>
                </constraints>
            </collectionViewCellContentView>
            <viewLayoutGuide key="safeArea" id="lEC-sa"/>
            <connections>
                <outlet property="cardView"         destination="lEC-card"      id="lEC-o1"/>
                <outlet property="homeLogoImage"    destination="lEC-home-img"  id="lEC-o2"/>
                <outlet property="awayLogoImage"    destination="lEC-away-img"  id="lEC-o3"/>
                <outlet property="homeNameLabel"    destination="lEC-home-lbl"  id="lEC-o4"/>
                <outlet property="awayNameLabel"    destination="lEC-away-lbl"  id="lEC-o5"/>
                <outlet property="scoreLabel"       destination="lEC-score"     id="lEC-o6"/>
                <outlet property="dateLabel"        destination="lEC-date"      id="lEC-o7"/>
                <outlet property="statusBadgeView"  destination="lEC-st-view"   id="lEC-o8"/>
                <outlet property="statusLabel"      destination="lEC-st-lbl"    id="lEC-o9"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>
